# OpenClaw agent container with agentos-agent skill
# Agents are OpenClaw instances — this image bundles the skill for easy deployment.
FROM node:20-alpine
WORKDIR /app

# Copy the agentos-agent skill
COPY skills/agentos-agent/ skills/agentos-agent/

# The agent is an OpenClaw instance configured with:
#   OC_AGENTOS_HOMESERVER    — Matrix homeserver URL
#   OC_AGENTOS_ACCESS_TOKEN  — Matrix access token
#   OC_AGENTOS_USER_ID       — Matrix user ID
#   OC_AGENTOS_AGENT_NAME    — Display name
#   OC_AGENTOS_CAPABILITIES  — Comma-separated capabilities
#
# Mount or install OpenClaw separately. This image provides only the skill files.
