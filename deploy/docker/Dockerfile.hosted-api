# Hosted API — handles auth, space provisioning, and operator wiring
FROM node:20-alpine AS builder
WORKDIR /app
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml tsconfig.base.json ./
COPY packages/ packages/
COPY apps/hosted-api/ apps/hosted-api/
RUN corepack enable && pnpm install --frozen-lockfile
RUN pnpm --filter @openclaw/protocol build
RUN pnpm --filter @openclaw/hosted-api build
RUN pnpm --filter @openclaw/hosted-api deploy --prod /deploy

FROM node:20-alpine
WORKDIR /app
RUN apk add --no-cache tini
COPY --from=builder /deploy /app

ENV NODE_ENV=production
EXPOSE 3001
USER 1000:1000
ENTRYPOINT ["tini", "--"]
CMD ["node", "dist/index.js"]
